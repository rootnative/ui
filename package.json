{
  "name": "rootnative-ui",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "turbo run build --filter=./packages/*",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "check": "turbo run lint typecheck",
    "dev": "turbo run dev",
    "clean": "turbo run clean",
    "clean:cache": "pnpm clean:deep && echo '✨ All caches cleaned!'",
    "clean:deep": "rm -rf node_modules .turbo .expo dist build && pnpm -r exec rm -rf node_modules dist build .turbo .expo && pnpm store prune && watchman watch-del-all 2>/dev/null || true && rm -rf $TMPDIR/metro-* $TMPDIR/haste-* $TMPDIR/react-* 2>/dev/null || true",
    "example": "pnpm --filter example start",
    "format": "prettier . --write",
    "docs:dev": "pnpm --filter @rootnative/docs dev",
    "docs:build": "pnpm --filter @rootnative/docs build",
    "build:llms": "tsx scripts/build-llms.ts",
    "docs:serve": "pnpm --filter @rootnative/docs serve",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.0.0",
    "eslint-plugin-react-hooks": "^4.0.0",
    "eslint-plugin-react-native": "^4.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.0.0",
    "turbo": "^2.8.21",
    "typescript-eslint": "^8.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.{js,json,css}": [
      "prettier --check"
    ]
  },
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "react-native": "0.81.5",
      "react-native-safe-area-context": "5.6.2"
    }
  }
}
