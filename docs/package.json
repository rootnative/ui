{
  "name": "@rootnative/docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "prepare:demo": "node scripts/prepare-demo.mjs",
    "prepare:demo:force": "node scripts/prepare-demo.mjs --force",
    "dev": "pnpm prepare:demo && docusaurus start",
    "build": "pnpm prepare:demo:force && docusaurus build",
    "typecheck": "tsc --noEmit",
    "serve": "docusaurus serve",
    "clean": "rm -rf build .docusaurus static/demo"
  },
  "dependencies": {
    "@docusaurus/core": "^3.10.0",
    "@docusaurus/preset-classic": "^3.10.0",
    "@easyops-cn/docusaurus-search-local": "^0.55.1",
    "@mdx-js/react": "^3.0.0",
    "clsx": "^2.0.0",
    "prism-react-renderer": "^2.3.0",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.10.0",
    "@docusaurus/tsconfig": "^3.10.0",
    "@docusaurus/types": "^3.10.0",
    "docusaurus-plugin-react-docgen-typescript": "^1.3.0",
    "react-docgen-typescript": "^2.2.2",
    "typescript": "^5.0.0"
  }
}
