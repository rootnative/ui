{
  "name": "@rootnative/icons",
  "version": "0.0.0-alpha.0",
  "description": "Icon library adapters for RootNative — Lucide, Phosphor, and @expo/vector-icons resolvers with MDI-name compatibility.",
  "private": false,
  "sideEffects": false,
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "react-native": "dist/index.mjs",
  "source": "src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "react-native": "./dist/index.mjs",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "llms.txt"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rootnative/ui.git",
    "directory": "packages/icons"
  },
  "homepage": "https://github.com/rootnative/ui",
  "keywords": [
    "react-native",
    "material-design-3",
    "icons",
    "lucide",
    "phosphor",
    "vector-icons",
    "md3"
  ],
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm --outDir dist --clean --external lucide-react-native --external phosphor-react-native --external @expo/vector-icons --external react --external react-native",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "lint": "eslint . --max-warnings 0"
  },
  "peerDependencies": {
    "@rootnative/core": ">=0.0.0-alpha.0",
    "react": ">=18.0.0",
    "react-native": ">=0.72.0"
  },
  "peerDependenciesMeta": {
    "lucide-react-native": {
      "optional": true
    },
    "phosphor-react-native": {
      "optional": true
    },
    "@expo/vector-icons": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rootnative/core": "workspace:*",
    "@react-native/babel-preset": "^0.81.5",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.0.0",
    "jest": "^29.7.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-test-renderer": "19.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
