{
  "name": "@rootnative/cli",
  "version": "0.0.0-alpha.0",
  "description": "CLI for adding RootNative UI components to your React Native project",
  "private": false,
  "bin": {
    "rootnative": "dist/index.mjs"
  },
  "exports": "./dist/index.mjs",
  "files": [
    "dist",
    "llms.txt"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rootnative/ui.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/rootnative/ui",
  "keywords": [
    "react-native",
    "material-design-3",
    "ui",
    "cli",
    "components",
    "rootnative"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint . --max-warnings 0"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "execa": "^9.5.2",
    "fs-extra": "^11.3.0",
    "ora": "^8.2.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.0.0",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.2.1"
  }
}
