{
  "name": "@rootnative/core",
  "version": "0.0.0-alpha.1",
  "description": "Design-system agnostic theme engine for RootNative UI — a React Native component library. Ships with Material Design 3 out of the box.",
  "private": false,
  "sideEffects": false,
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "react-native": "dist/index.mjs",
  "source": "src/index.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.mts",
      "react-native": "./dist/index.mjs",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./create-theme": {
      "types": "./dist/create-theme/index.d.mts",
      "react-native": "./dist/create-theme/index.mjs",
      "import": "./dist/create-theme/index.mjs",
      "default": "./dist/create-theme/index.mjs"
    }
  },
  "typesVersions": {
    "*": {
      "create-theme": [
        "dist/create-theme/index.d.mts"
      ]
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "llms.txt"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rootnative/ui.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/rootnative/ui",
  "keywords": [
    "react-native",
    "material-design-3",
    "theme",
    "ui",
    "md3"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/create-theme/index.ts --dts --format esm --outDir dist --clean",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "lint": "eslint . --max-warnings 0"
  },
  "peerDependencies": {
    "@material/material-color-utilities": ">=0.4.0",
    "@rootnative/inertia": ">=0.0.0-alpha.2",
    "react": ">=18.0.0",
    "react-native": ">=0.72.0"
  },
  "peerDependenciesMeta": {
    "@material/material-color-utilities": {
      "optional": true
    }
  },
  "devDependencies": {
    "@material/material-color-utilities": "^0.4.0",
    "@react-native/babel-preset": "^0.81.5",
    "@rootnative/inertia": "^0.0.0-alpha.2",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.0.0",
    "jest": "^29.7.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-test-renderer": "19.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
